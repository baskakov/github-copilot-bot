# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# GitHub OAuth token obtained via device flow (run: npm run auth)
# This is required to access the full Copilot model catalog (Claude, GPT-4.5, o1, etc.)
GITHUB_TOKEN=your_github_oauth_token_here

# GitHub Organization slug
GITHUB_ORG=Bask-Agency

# Comma-separated list of allowed Telegram user IDs (numeric)
# Example: 123456789,987654321
ALLOWED_USER_IDS=123456789,987654321

